{
    "name": "agence-globale-postgres-sink",
    "config": {
      "connector.class": "io.debezium.connector.jdbc.JdbcSinkConnector",
      "tasks.max": "3",
      "topics": "agence1.nanp_db.ventes,agence2.nanp_db.ventes",
      "connection.url": "jdbc:postgresql://postgres-globale:5432/global_db",
      "connection.username": "user",
      "connection.password": "password",
      "insert.mode": "insert",
      "table.name.format": "ventes_globales",
      "auto.create": "false",
      "pk.mode": "none",

      "key.converter": "org.apache.kafka.connect.json.JsonConverter",
      "value.converter": "org.apache.kafka.connect.json.JsonConverter",
      "header.converter": "org.apache.kafka.connect.storage.SimpleHeaderConverter",
      "delete.enabled": false,
      "truncate.enabled": false,
      "quote.identifiers": false,
      "dialect.sqlserver.identity.insert": false,
      "errors.log.enable": false,
      "errors.log.include.messages": false,
      "errors.deadletterqueue.context.headers.enable": false
    }
}