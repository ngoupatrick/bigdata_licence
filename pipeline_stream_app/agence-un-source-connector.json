{
    "name": "agence-un-source-connector",
    "config": {
        "connector.class": "io.debezium.connector.mysql.MySqlConnector", 
        "tasks.max": "1",
        "database.hostname": "mysql-agence1", 
        "database.port": "3306", 
        "database.user": "root", 
        "database.password": "mysql", 
        "database.server.id": "1", 
        "topic.prefix": "agence1", 
        "database.include.list": "nanp_db",
        "table.include.list": "nanp_db.ventes",       
        "include.schema.changes": "true",

        "topic.creation.enable": true,
        "topic.creation.default.partitions": "1",
        "topic.creation.default.replication.factor": "1",
        
        "schema.history.internal.kafka.bootstrap.servers": "redpanda:9092", 
        "schema.history.internal.kafka.topic": "schema-changes.agence1", 

        "key.converter.schema.registry.url": "http://redpanda:8081",
        "value.converter.schema.registry.url": "http://redpanda:8081",

        "slot.name": "debezium_client_slot",
        "publication.name": "dbz_client_publication",
        "publication.autocreate.mode": "disabled",
        "snapshot.mode": "initial",
        "heartbeat.interval.ms": "30000",
        
        "decimal.handling.mode": "double",
        "time.precision.mode": "connect",
        "max.batch.size": "2048",
        "max.queue.size": "8192",
        
        "errors.retry.delay.max.ms": "60000",
        "errors.retry.timeout": "300000",
        "errors.tolerance": "all",
        "errors.log.enable": "true",
        "errors.deadletterqueue.topic.name": "dead_letter_queue",
        "errors.deadletterqueue.context.headers.enable": "true"


    }
}